    "r3": "reserved"
  },
  "tier": "Tier-B",
  "parentActor": null,
  "crossActorBoundary": [
    "did:web:danjo.etzhayyim.com (PRIMARY UPSTREAM + BOUNDARY: danjo = non-adjudicating cross-reference ENGINE emitting fiscal + intergov-fund-flow datoms; kanae = fiscal-flow ASSEMBLY + Murakumo NARRATIVE + kami-engine WASM VISUALIZATION. danjo finds, kanae renders. kanae reads danjo datoms read-only and never writes back; ADR-2605301600 + ADR-2605302245)",
    "com.etzhayyim.gov.dataset.* corpus (ADR-2605263900): READ-ONLY budgetRecord / procurementRecord / statisticsObservation (IMF SDMX / World Bank / OECD / UN) — fiscal-flow input where danjo has not yet indexed a jurisdiction",
    "did:web:ossekai.etzhayyim.com (kanae aggregate visualizations → ossekai §1.12 aggregate-anonymized publication; ADR-2605264000)",
    "did:web:kataribe.etzhayyim.com (kanae visualization artifacts = citable primary-source graphics for press / publishing)",
    "did:web:toritate.etzhayyim.com (∥ disjoint: toritate visualizes the religious-corp's OWN on-chain books; kanae visualizes the STATE's published fiscal flows)",
    "maps actor (∥ sibling visualization actor, disjoint domain geo-vs-fiscal AND disjoint backend: maps = RisingWave; kanae = kotoba EAVT per G2/N13)",
    "kami-engine (ADR-2605261800): WASM render substrate (G14); visualizationManifest compiles to a kami-engine scene reusing isekai/omniverse WASM viewer assets",
    "kotoba QuadStore EAVT (fund-flow graph store; ADR-2605262130; no RisingWave / no projection layer)"
  ],
  "lexiconReadAccess": {
    "com.etzhayyim.gov.dataset.budgetRecord": "ADR-2605263900; READ-ONLY appropriation / outlay / subaward (USAspending / EU FTS / HM Treasury OSCAR / JP 予算書). Assembled into kotoba EAVT fundFlowEdge by kanae_flow_assembler.",
    "com.etzhayyim.gov.dataset.procurementRecord": "ADR-2605263900; READ-ONLY tender / award (EU TED / US SAM.gov / UK Contracts Finder / JP 政府調達). awardeeLei cross-link to corp.leiReference.",
    "com.etzhayyim.gov.dataset.statisticsObservation": "ADR-2605263900; READ-ONLY IMF SDMX / World Bank / OECD.Stat / UN data — inter-governmental transfer / aid / loan flows. Assembled by kanae_intergov_flow.",
    "com.etzhayyim.corp.leiReference": "ADR-2605263800; READ-ONLY GLEIF LEI canonical for recipient / awardee endpoint resolution. CC0 1.0.",
    "com.etzhayyim.corp.ownershipEdge": "ADR-2605263800; READ-ONLY UBO / parent-subsidiary for flow-edge endpoint resolution. GLEIF L2 (CC0) + OpenCorporates open-data.",
    "com.etzhayyim.danjo.crossReferenceLink": "ADR-2605301600; READ-ONLY danjo cross-reference edges (engine output).",
    "com.etzhayyim.danjo.discrepancyObservation": "ADR-2605301600; READ-ONLY danjo non-adjudicating observations (engine output; kanae may surface them in a visualization, NON-adjudicating pass-through, never re-characterized)."
  },
  "form": "任意団体 internal civic-transparency fiscal-flow visualization substrate (NOT 一般社団 / NPO / 公益財団 / 宗教法人 法人格 — Preamble §0.4 Lv7+ unanimity lock; NOT a state-recognized audit organ; NOT a commercial fiscal-intelligence product)",
  "constitutionalDiscipline": {
    "nonAdjudicating": "G4 — UPL-equivalent (mirrors danjo G4 / chigiri G14 / toritate G5). kanae emits FACTUAL flow descriptions only; it MUST NOT assert that a crime / 不正 / violation occurred. Every flowNarrative carries nonAdjudicatingNotice=true; the fundFlowEdge flowClass enum carries no verdict token. Legal characterization via external counsel (chigiri + Public Fund Council Lv6+).",
    "kotobaNativePersistence": "G2 — fund-flow graph lives in kotoba EAVT; RisingWave / Postgres / Lance / DuckDB / SQLite PROHIBITED as primary store or read backend (ADR-2605262130). The maps RisingWave backend is NOT a template.",
    "passiveOnlyUpstream": "G3 — reads ONLY the pre-published IPFS-pinned gov.dataset.* corpus + danjo datoms. No live portal scraping, no per-query API, no non-public sources, no whistleblower intake (§2(c)).",
    "sourceProvenanceMandatory": "G5 — every fundFlowEdge + flowNarrative cites ≥2 upstream gov.dataset.* / danjo record CIDs.",
    "openMethod": "G6 — every aggregation + narrative-prompt heuristic published as a methodNote (open, versioned).",
    "murakumoOnlyInference": "G7 — flowNarrative LLM analysis on Murakumo fleet ONLY (ADR-2605215000). murakumoInferenceAttestation mandatory; vendor-LLM origin unrepresentable at schema layer.",
    "aggregateFirstVisualization": "G10 — every visualization aggregate by default; named-party element only where source records already name the party AND severity-gated + Council-reviewed; no per-individual targeting (N9).",
    "transparentForce": "G11 — assembly + narrative + visualization + publication ONLY. No coercion, no state-coercion dependency, no covert op. 1 SBT = 1 vote governs named-party publication (§1.12).",
    "noCommercialGovIntel": "G8 — GovWin IQ / Bloomberg Government / Politico Pro / E&E News Pro / FiscalNote / CQ Roll Call Pro PROHIBITED (§2(e) anti-gatekeeping). Deny-list lint.",
    "kamiEngineRenderOnly": "G14 — render substrate = kami-engine WASM (ADR-2605261800), reproducible from public kotoba datoms. NO third-party BI (Tableau / Power BI / Looker / Palantir Foundry) as render or fusion layer.",
    "noAdAnalyticsSdk": "G15 — render path carries NO GA4 / Meta Pixel / affiliate / third-party analytics SDK (Substrate boundary Advertising row). Lint-enforced.",
    "readOnly": "G12 — never mutates upstream gov.dataset.* / danjo records nor any on-chain contract."
  },
  "scope": {
    "phase": "R0 scaffold",
    "scopeBoundary": "Assembly of pre-published global fiscal flows (domestic full chain + inter-governmental) into kotoba EAVT + Murakumo-LLM non-adjudicating narrative + aggregate-first kami-engine WASM visualization + Council-attested publication. Global / jurisdiction-generic architecture from R0; JP-first → multi-jurisdiction activation ramp follows danjo + corpus.",
    "exclusions": [
      "prosecutor / law-enforcement arm",
      "court / adjudicator of guilt or of 'violation'",
      "surveillance system (live monitoring of individuals)",
      "commercial gov-intelligence / fiscal-intelligence product (GovWin / Bloomberg Government / FiscalNote / Palantir)",
      "whistleblower-intake / non-public-leak handler",
      "state-granted legal personality (NOT 宗教法人法 登記)",
      "closed-source / secret-aggregation engine",
      "partisan / electioneering tool",
      "per-individual reputation / social-credit score",
      "replacement for the state's own audit organs (会計検査院 / GAO / ECA)",
      "defamation vector (structurally prevented by G4/G5/G10)",
      "vendor-LLM inference path (Murakumo-only)",
      "substrate-engine or projection-layer replacement (kotoba canonical; no RisingWave like maps)",
      "third-party-BI / Palantir-class fusion dashboard (render = kami-engine WASM)"
    ]
  },
  "cells": [
    {
      "name": "flow_assembler",
      "module": "kotodama.cells.kanae_flow_assembler",
      "murakumoNode": "reuben",
      "phase": "continuous",
      "io": "danjo budget_ledger + procurement_graph datoms + gov.dataset.{budgetRecord,procurementRecord} → kotoba EAVT fundFlowEdge datoms (domestic full chain: appropriation ↔ outlay ↔ subaward ↔ award ↔ recipientLei)"
    },
    {
      "name": "intergov_flow",
      "module": "kotodama.cells.kanae_intergov_flow",
      "murakumoNode": "reuben",
      "phase": "continuous",
      "io": "gov.dataset.statisticsObservation (IMF SDMX / World Bank / OECD / UN) → fundFlowEdge datoms (flowClass = intergovernmental-transfer / aid-disbursement / loan; donor-juris ↔ recipient-juris ↔ instrument ↔ amount ↔ period)"
    },
    {
      "name": "flow_narrative",
      "module": "kotodama.cells.kanae_flow_narrative",
      "murakumoNode": "gad",
      "phase": "continuous",
      "io": "fundFlowEdge subgraph → Murakumo-LLM flowNarrative (factual, source-cited, NON-adjudicating; G4 + G5 + G7)"
    },
    {
      "name": "viz_compiler",
      "module": "kotodama.cells.kanae_viz_compiler",
      "murakumoNode": "gad",
      "phase": "periodic (event)",
      "io": "fundFlowEdge subgraph + flowNarrative → visualizationManifest (kami-engine WASM scene; aggregate-first; each manifest carries the reproducing kotoba-kqe query)"
    },
    {
      "name": "publish",
      "module": "kotodama.cells.kanae_publish",
      "murakumoNode": "naphtali",
      "phase": "periodic (event)",
      "io": "aggregate visualizationManifest → published IPFS-pinned artifact + Council Lv6+ ≥3 attestation chain"
    }
  ],
  "lexiconNamespaces": [
    "com.etzhayyim.kanae.fundFlowEdge",
    "com.etzhayyim.kanae.flowNarrative",
    "com.etzhayyim.kanae.visualizationManifest",
    "com.etzhayyim.kanae.methodNote"
  ],
  "constitutionalGates": {
    "description": "15 immutable gates per ADR-2605302300 §4 (G1–G13 inherit the danjo gate set; G14–G15 are visualization-specific). Council Lv6+ supermajority + new ADR to amend.",
    "gates": {
      "G1": "Charter Rider §2(a)-(h) scan on every published narrative + manifest + artifact",
      "G2": "kotoba EAVT persistence — RisingWave / Postgres / Lance / DuckDB / SQLite PROHIBITED as primary store or read backend (the maps RisingWave backend is NOT a template)",
      "G3": "Passive-only / upstream-only ingestion — only pre-published IPFS-pinned gov.dataset.* + danjo datoms; no live scraping / no per-query API / no non-public sources / no whistleblower intake (§2(c))",
      "G4": "NON-adjudicating (UPL-equivalent) — flowNarrative nonAdjudicatingNotice const true; fundFlowEdge flowClass enum carries no crime/violation/guilt token; legal characterization via external counsel (chigiri + Public Fund)",
      "G5": "Source-provenance mandatory — ≥2 upstream gov.dataset.* / danjo record CIDs per fundFlowEdge + flowNarrative",
      "G6": "Open method — every aggregation + narrative-prompt heuristic published as methodNote (open, versioned)",
      "G7": "Murakumo-only inference (ADR-2605215000) — flowNarrative LLM on Murakumo fleet only; murakumoInferenceAttestation mandatory; vendor-LLM origin unrepresentable",
      "G8": "No commercial gov-intelligence terminals (GovWin IQ / Bloomberg Government / Politico Pro / E&E News Pro / FiscalNote / CQ Roll Call Pro PROHIBITED)",
      "G9": "Per-jurisdiction publication-rule honoring — no unilateral re-identification; DSARs route via chigiri.data_privacy; kanae never adds/removes PII",
      "G10": "Aggregate-first visualization — named-party element only where source records already name the party AND severity-gated + Council-reviewed; no per-individual targeting",
      "G11": "Transparent Religious Force discipline (§1.12) — assembly + narrative + visualization + publication ONLY; no coercion; no state-coercion dependency; no covert op; 1 SBT = 1 vote governs named-party publication",
      "G12": "Read-only — never mutates upstream gov.dataset.* / danjo records nor any on-chain contract",
      "G13": "stateAlignedFlag pass-through — CN-class / state-aligned sources carry the flag into every derived fundFlowEdge / flowNarrative / visualizationManifest",
      "G14": "kami-engine WASM render-only (ADR-2605261800), reproducible from public kotoba datoms — NO third-party BI (Tableau / Power BI / Looker / Palantir Foundry) as render or fusion layer",
      "G15": "No ad / analytics SDK in the render path — NO GA4 / Meta Pixel / affiliate / third-party analytics SDK (Substrate boundary Advertising row)"
    }
  },
  "nonGoals": {
    "description": "14 explicitly excluded scopes",
    "goals": {
